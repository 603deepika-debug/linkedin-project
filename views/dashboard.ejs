
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — LI Scraper</title>

  <link rel="stylesheet" href="/css/app.css" />

</head>

<body>

<%- include('partials/sidebar', { page:'dashboard' }) %>


<main class="main">

<header class="topbar">
<h1 class="topbar-title">Dashboard</h1>
</header>


<div class="content">


<div class="hero-stat">

<div class="stat-box">
<div class="stat-num">10</div>
<div class="stat-label">Endpoints</div>
</div>


<div class="stat-box">
<div class="stat-num">3</div>
<div class="stat-label">Categories</div>
</div>


<div class="stat-box">
<div class="stat-num">LIVE</div>
<div class="stat-label">Real-Time</div>
</div>

</div>



<!-- PROFILE -->

<div class="section-header">
Profile Endpoints
</div>


<div class="dashboard-grid">


<a href="/linkedin/profile/detail" class="endpoint-card">
<span class="ec-method ec-get">GET</span>
<div class="ec-name">Profile Detail</div>
<div class="ec-path">/profile/detail</div>
<div class="ec-desc">Full LinkedIn profile information</div>
</a>



<a href="/linkedin/profile/posts" class="endpoint-card">
<span class="ec-method ec-get">GET</span>
<div class="ec-name">Profile Posts</div>
<div class="ec-path">/profile/posts</div>
<div class="ec-desc">Recent profile posts</div>
</a>



<a href="/linkedin/profile/comments" class="endpoint-card">
<span class="ec-method ec-get">GET</span>
<div class="ec-name">Profile Comments</div>
<div class="ec-path">/profile/comments</div>
<div class="ec-desc">Profile comments activity</div>
</a>



<a href="/linkedin/profile/reactions" class="endpoint-card">
<span class="ec-method ec-get">GET</span>
<div class="ec-name">Profile Reactions</div>
<div class="ec-path">/profile/reactions</div>
<div class="ec-desc">Likes and reactions</div>
</a>



<a href="/linkedin/profile/contact" class="endpoint-card">
<span class="ec-method ec-get">GET</span>
<div class="ec-name">Profile Contact</div>
<div class="ec-path">/profile/contact</div>
<div class="ec-desc">Contact information</div>
</a>



<a href="/linkedin/profile/upload" class="endpoint-card">
<span class="ec-method ec-post">POST</span>
<div class="ec-name">Upload Profile</div>
<div class="ec-path">/profile/upload</div>
<div class="ec-desc">Import profile using URL</div>
</a>



</div>





<!-- COMPANY -->

<div class="section-header">
Company Endpoints
</div>


<div class="dashboard-grid">


<a href="/linkedin/company/detail" class="endpoint-card">

<span class="ec-method ec-get">GET</span>

<div class="ec-name">
Company Detail
</div>

<div class="ec-path">
/company/detail
</div>

<div class="ec-desc">
Company overview details
</div>

</a>




<a href="/linkedin/company/posts" class="endpoint-card">

<span class="ec-method ec-get">GET</span>

<div class="ec-name">
Company Posts
</div>

<div class="ec-path">
/company/posts
</div>

<div class="ec-desc">
Company activity posts
</div>

</a>



</div>






<!-- SEARCH -->

<div class="section-header">
Search Endpoints
</div>


<div class="dashboard-grid">


<a href="/linkedin/search/companies" class="endpoint-card">

<span class="ec-method ec-get">GET</span>

<div class="ec-name">
Search Companies
</div>

<div class="ec-path">
/search/companies
</div>

<div class="ec-desc">
Find companies by keyword
</div>

</a>




<a href="/linkedin/search/jobs" class="endpoint-card">

<span class="ec-method ec-get">GET</span>

<div class="ec-name">
Search Jobs
</div>

<div class="ec-path">
/search/jobs
</div>

<div class="ec-desc">
Find LinkedIn jobs
</div>

</a>




<a href="/linkedin/job/detail" class="endpoint-card">

<span class="ec-method ec-get">GET</span>

<div class="ec-name">
Job Detail
</div>

<div class="ec-path">
/job/detail
</div>

<div class="ec-desc">
Single job information
</div>

</a>



</div>



</div>

</main>


<script src="/js/app.js"></script>


</body>
</html>