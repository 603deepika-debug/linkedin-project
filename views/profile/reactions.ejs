<!DOCTYPE html>
<html lang="en">


<head>


<meta charset="UTF-8">

<meta name="viewport" content="width=device-width,initial-scale=1.0">


<title>Profile Reactions</title>


<link rel="stylesheet" href="/css/app.css">



<style>


.reaction-card{

background:var(--bg2);

border:1px solid var(--border);

padding:20px;

border-radius:15px;

margin-top:20px;


}



.header{

display:flex;

gap:15px;

align-items:center;


}



.avatar{

height:60px;

width:60px;

border-radius:50%;

object-fit:cover;

background:#ddd;

}



.name{

font-weight:700;

font-size:18px;


}



.headline{

font-size:13px;

color:gray;

}



.reaction{

margin-top:15px;

background:var(--bg3);

padding:10px;

border-radius:20px;

display:inline-block;


}



.post{


margin-top:15px;

background:var(--bg3);

padding:15px;

border-radius:10px;

line-height:1.5;


}



.stats{

display:flex;

gap:20px;

margin-top:15px;

color:gray;

font-size:14px;


}



</style>


</head>




<body>



<%- include('../partials/sidebar',{page:'profile-reactions'}) %>




<main class="main">



<header class="topbar">


<h1 class="topbar-title">

Profile Reactions

</h1>


</header>







<div class="content">





<div class="card">


<form method="POST">


<input

name="profile_url"

placeholder="Linkedin profile url"

value="<%= profile_url || '' %>"

required

>


<button class="btn btn-primary">

Fetch →

</button>


</form>


</div>









<%

let reactions=[];


if(result){

reactions =
result.data?.reactions || [];

}


%>








<% reactions.forEach(item=>{ %>





<div class="reaction-card">





<div class="header">





<img

src="<%= item.author?.profile_picture || '' %>"

class="avatar"

/>






<div>


<div class="name">


<%= item.author?.firstName %>

<%= item.author?.lastName %>


</div>



<div class="headline">


<%= item.author?.headline %>


</div>



</div>


</div>







<div class="reaction">


❤️ <%= item.action %>

</div>







<div class="post">


<strong>

Post

</strong>


<p>

<%= item.text.substring(0,300) %>

...</p>


</div>







<div class="stats">


<span>

❤️

<%= item.post_stats?.totalReactionCount || 0 %>

Likes

</span>



<span>

💬

<%= item.post_stats?.comments || 0 %>

Comments

</span>



<span>

🕒

<%= item.timestamps?.relative || "" %>

</span>



</div>






</div>







<% }) %>







<% if(reactions.length===0 && result){ %>


<div class="card">

No reactions found

</div>


<% } %>






</div>


</main>



</body>


</html>