<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">


<title>Profile Reactions — LI Scraper</title>


<link rel="stylesheet" href="/css/app.css">



<style>


.reaction-card{

background:var(--bg2);

border:1px solid var(--border);

border-radius:15px;

padding:20px;

margin-top:20px;

}



.form-box{

background:var(--bg2);

border:1px solid var(--border);

border-radius:12px;

padding:20px;

}



.form-box form{

display:flex;

align-items:center;

gap:15px;

}



.form-box input{

width:500px;

padding:14px;

border-radius:8px;

border:1px solid var(--border);

font-size:14px;

}



.user{

display:flex;

gap:15px;

align-items:center;

}



.avatar{

width:60px;

height:60px;

border-radius:50%;

object-fit:cover;

background:#ddd;

}



.name{

font-size:18px;

font-weight:700;

}



.headline{

font-size:13px;

color:#999;

margin-top:5px;

}



.action{


margin-top:15px;

background:var(--bg3);

padding:10px 15px;

border-radius:20px;

display:inline-block;

font-size:13px;


}




.post{


margin-top:15px;

background:var(--bg3);

padding:15px;

border-radius:10px;

line-height:1.6;


}



.stats{


display:flex;

gap:25px;

margin-top:15px;

color:#aaa;

font-size:13px;


}




.link{


color:#38bdf8;

font-size:13px;

text-decoration:none;

}



</style>



</head>




<body>



<%- include('../partials/sidebar',{page:'profile-reactions'}) %>




<main class="main">




<header class="topbar">


<h1 class="topbar-title">

Profile Reactions

</h1>



<div class="topbar-meta">


<code class="endpoint-badge">

GET /profile/reactions

</code>


</div>



</header>






<div class="content">






<div class="form-box">


<form method="POST">



<input

type="text"

name="profile_url"

value="<%= profile_url || '' %>"

placeholder="https://linkedin.com/in/profile"

required

>



<button class="btn btn-primary">

Fetch →

</button>



</form>


</div>









<%

const reactions =

result?.data?.reactions ||

result?.data?.data?.reactions ||

result?.reactions ||

[];

%>









<% reactions.forEach(item=>{ %>






<div class="reaction-card">





<div class="user">





<% if(item.author?.profile_picture){ %>


<img

src="<%= item.author.profile_picture %>"

class="avatar"


>


<% }else{ %>


<div class="avatar"></div>


<% } %>





<div>



<div class="name">


<%= item.author?.firstName || "" %>

<%= item.author?.lastName || "" %>


</div>




<div class="headline">


<%= item.author?.headline || "No headline" %>


</div>




<a

class="link"

target="_blank"

href="<%= item.author?.profile_url || '#' %>">


View Profile


</a>



</div>



</div>








<div class="action">


❤️ <%= item.action || "Reaction" %>


</div>







<div class="post">


<strong>

Post

</strong>


<p>


<%= item.text?.substring(0,300) || "No post text" %>


...


</p>



</div>








<div class="stats">



<span>


❤️

<%= item.post_stats?.totalReactionCount || 0 %>

Likes


</span>





<span>


💬

<%= item.post_stats?.comments || 0 %>

Comments


</span>





<span>


🕒

<%= item.timestamps?.relative || "" %>


</span>



</div>





</div>





<% }) %>









<% if(reactions.length===0 && result){ %>


<div class="reaction-card">


No reactions found


</div>


<% } %>









</div>




</main>




</body>


</html>