<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Profile Detail</title>

<link rel="stylesheet" href="/css/app.css">


<style>

.profile-card{

background:var(--bg2);
border:1px solid var(--border);
border-radius:15px;
overflow:hidden;
margin-top:25px;

}


.cover{

height:170px;

background:
linear-gradient(135deg,#0066ff,#00d4aa);

}



.profile-body{

padding:25px;

}



.avatar{

width:110px;

height:110px;

border-radius:50%;

border:5px solid white;

object-fit:cover;

margin-top:-70px;

background:#ddd;

}



.name{

font-size:28px;

font-weight:800;

margin-top:15px;

}



.headline{

margin-top:8px;

color:var(--text2);

font-size:15px;

}



.about-box{


margin-top:20px;

background:var(--bg3);

padding:20px;

border-radius:12px;

line-height:1.6;


}



.info{

display:flex;

gap:15px;

flex-wrap:wrap;

margin-top:20px;

}



.info span{


background:var(--bg3);

padding:10px 15px;

border-radius:20px;


}



</style>


</head>



<body>


<%- include('../partials/sidebar',{page:'profile-detail'}) %>



<main class="main">



<header class="topbar">

<h1 class="topbar-title">

Profile Detail

</h1>


<div class="topbar-meta">

<code class="endpoint-badge">

GET /profile/detail

</code>

</div>

</header>





<div class="content">





<div class="card">


<div class="card-title">

Parameters

</div>



<form method="POST">


<div class="form-row">


<div class="form-group">


<label>

LinkedIn Profile URL

</label>


<input

type="text"

name="profile_url"

value="<%= profile_url || '' %>"

placeholder="https://linkedin.com/in/profile"

required

>


</div>


<button class="btn btn-primary">

Fetch →

</button>


</div>


</form>


</div>





<% if(error){ %>


<div class="alert alert-error">

<%= error %>

</div>


<% } %>






<% if(result){ %>


<%


const data = result.data?.basic_info || {};


const name =
data.fullname || "Unknown User";


const image =
data.profile_picture_url || "";


const headline =
data.headline || "";


const about =
data.about || "";


const location =
data.location?.full || "";



%>







<div class="profile-card">


<div class="cover"></div>




<div class="profile-body">





<img

src="<%= image %>"

class="avatar"

onerror="this.style.display='none'"

/>







<div class="name">


<%= name %>


</div>





<div class="headline">


<%= headline %>


</div>







<div class="info">


<% if(location){ %>


<span>

📍 <%= location %>

</span>


<% } %>




<% if(data.is_creator){ %>


<span>

⭐ Creator

</span>


<% } %>





<% if(data.open_to_work){ %>


<span>

🟢 Open To Work

</span>


<% } %>



</div>








<% if(about){ %>


<div class="about-box">


<h3>

📝 About

</h3>


<p>

<%= about %>

</p>



</div>



<% } %>






</div>


</div>





<% } %>





</div>



</main>


</body>


</html>