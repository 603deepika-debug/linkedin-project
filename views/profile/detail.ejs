<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Profile Detail — LI Scraper</title>


<link rel="preconnect" href="https://fonts.googleapis.com">

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">


<link rel="stylesheet" href="/css/app.css" />


<style>


.profile-card{

background:var(--bg2);

border:1px solid var(--border);

border-radius:12px;

overflow:hidden;

margin-top:20px;

}



.cover{

height:170px;

background:linear-gradient(135deg,#0a3d8f,#0a84ff,#00d4aa);

}



.profile-body{

padding:25px;

}




.avatar{

width:110px;

height:110px;

border-radius:50%;

border:4px solid white;

object-fit:cover;

margin-top:-65px;

background:#ddd;

}




.name{

font-size:26px;

font-weight:800;

margin-top:15px;

}




.headline{

margin-top:8px;

font-size:15px;

color:var(--text2);

line-height:1.5;

}




.about{

margin-top:15px;

font-size:14px;

line-height:1.6;

color:var(--text2);

}



.info{

margin-top:20px;

display:flex;

gap:15px;

flex-wrap:wrap;

}



.info span{

background:var(--bg3);

padding:8px 15px;

border-radius:20px;

font-size:13px;

}



.section{

background:var(--bg2);

border:1px solid var(--border);

border-radius:12px;

padding:20px;

margin-top:20px;

}



.section h2{

font-size:18px;

margin-bottom:10px;

}



pre{

white-space:pre-wrap;

font-size:12px;

overflow:auto;

}



</style>



</head>



<body>


<%- include('../partials/sidebar', { page:'profile-detail' }) %>



<main class="main">



<header class="topbar">


<h1 class="topbar-title">

Profile Detail

</h1>



<div class="topbar-meta">

<code class="endpoint-badge">

GET /profile/detail

</code>

</div>


</header>




<div class="content">





<div class="card">


<div class="card-title">

Parameters

</div>



<form method="POST">


<div class="form-row">



<div class="form-group">


<label>

LinkedIn Profile URL

</label>



<input

type="text"

name="profile_url"

value="<%= profile_url || '' %>"

placeholder="https://www.linkedin.com/in/profile"

required

/>



</div>



<button class="btn btn-primary">

Fetch →

</button>



</div>



</form>



</div>







<% if(error){ %>


<div class="alert alert-error">

⚠ <%= error %>

</div>


<% } %>









<% if(result){ %>


<%


const data = result.data?.basic_info || {};



const name =

data.fullname ||

(data.first_name + " " + data.last_name);



const photo =

data.profile_picture_url || "";



const headline =

data.headline || "";



const location =

data.location?.full || "";



const about =

data.about || "";



%>









<div class="profile-card">


<div class="cover"></div>




<div class="profile-body">





<% if(photo){ %>


<img

src="<%= photo %>"

class="avatar"

onerror="this.style.display='none'"

/>


<% }else{ %>


<div class="avatar"></div>


<% } %>






<div class="name">

<%= name || "Unknown User" %>

</div>






<div class="headline">

<%= headline %>

</div>








<% if(about){ %>


<div class="about">

<%= about %>

</div>


<% } %>







<div class="info">





<% if(location){ %>

<span>

📍 <%= location %>

</span>

<% } %>






<% if(data.is_creator){ %>

<span>

⭐ Creator

</span>

<% } %>






<% if(data.open_to_work){ %>

<span>

🟢 Open To Work

</span>

<% } %>





</div>




</div>


</div>









<div class="section">


<h2>

📝 About

</h2>


<p>

<%= about %>

</p>


</div>








<div class="section">


<h2>

Raw Data

</h2>



<pre>

<%= JSON.stringify(result,null,2) %>

</pre>



</div>






<% } %>





</div>



</main>




<script src="/js/app.js"></script>



</body>


</html>