<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Profile Comments — LI Scraper</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/css/app.css" />


<style>

.comment-card{

background:var(--bg2);
border:1px solid var(--border);
border-radius:12px;
padding:20px;
margin-top:20px;

}


.comment-header{

display:flex;
gap:15px;
align-items:center;

}


.comment-avatar{

width:55px;
height:55px;
border-radius:50%;
object-fit:cover;
background:#ddd;

}


.comment-name{

font-weight:700;
font-size:16px;

}


.comment-sub{

font-size:12px;
color:var(--text3);

}



.comment-text{

margin-top:15px;
font-size:14px;
line-height:1.6;
color:var(--text2);

}



.post-box{

margin-top:15px;
background:var(--bg3);
padding:15px;
border-radius:8px;
font-size:13px;

}


.stats{

display:flex;
gap:20px;
margin-top:15px;
font-size:12px;
color:var(--text3);

}


.linkedin-link{

color:var(--accent);

}



</style>


</head>


<body>


<%- include('../partials/sidebar', { page:'profile-comments' }) %>


<main class="main">


<header class="topbar">

<h1 class="topbar-title">
Profile Comments
</h1>


<div class="topbar-meta">

<code class="endpoint-badge">
GET /profile/comments
</code>

</div>


</header>



<div class="content">



<div class="card">


<div class="card-title">
Parameters
</div>



<form method="POST" action="/linkedin/profile/comments">


<div class="form-row">


<div class="form-group">


<label>
LinkedIn Profile URL
</label>



<input

type="text"

name="profile_url"

value="<%= profile_url || '' %>"

placeholder="https://www.linkedin.com/in/satya-nadella"

required

/>


</div>



<button class="btn btn-primary">

Fetch →

</button>


</div>


</form>


</div>





<% if(error){ %>


<div class="alert alert-error">

<%= error %>

</div>


<% } %>





<%

let comments=[];


if(result && result.data && result.data.comments){

comments=result.data.comments;

}


%>





<% comments.forEach(comment=>{ %>


<div class="comment-card">


<div class="comment-header">



<img

class="comment-avatar"

src="<%= comment.commenter?.profile_picture %>"

onerror="this.style.display='none'"

/>



<div>


<div class="comment-name">

<%= comment.commenter?.name || 'Unknown User' %>

</div>


<div class="comment-sub">

<%= comment.commenter?.subtitle || '' %>

</div>


<a class="linkedin-link"

href="<%= comment.commenter?.linkedin_url %>"

target="_blank">

View Profile

</a>


</div>



</div>





<div class="comment-text">


<%= comment.comment_text %>


</div>





<div class="post-box">


<strong>
Original Post
</strong>


<p>

<%= comment.post?.post_text?.substring(0,300) %>

...

</p>


</div>





<div class="stats">


<span>
❤️ <%= comment.stats?.total_reactions || 0 %> Reactions
</span>


<span>
💬 <%= comment.stats?.comments || 0 %> Comments
</span>



<span>

🕒 <%= comment.created_at?.relative || '' %>

</span>



</div>



</div>



<% }) %>







<% if(comments.length===0 && result){ %>


<div class="card">

No comments found

</div>


<% } %>






</div>


</main>



<script src="/js/app.js"></script>


</body>


</html>