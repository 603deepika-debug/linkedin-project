<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Upload Profile — LI Scraper</title>


<link rel="preconnect" href="https://fonts.googleapis.com">

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">


<link rel="stylesheet" href="/css/app.css" />



<style>


.upload-result{

margin-top:20px;

background:var(--bg2);

border:1px solid var(--border);

border-radius:12px;

padding:20px;

}



.success-box{

background:rgba(0,212,170,.12);

border:1px solid #00d4aa;

padding:15px;

border-radius:10px;

color:#00d4aa;

}



.error-box{

background:rgba(255,0,0,.1);

border:1px solid red;

padding:15px;

border-radius:10px;

color:red;

}



.profile-preview{

display:flex;

gap:20px;

align-items:center;

margin-top:20px;

}



.preview-img{

width:80px;

height:80px;

border-radius:50%;

object-fit:cover;

}



.preview-name{

font-size:20px;

font-weight:800;

}



.preview-text{

color:var(--text2);

font-size:14px;

}



</style>



</head>



<body>



<%- include('../partials/sidebar', { page:'profile-upload' }) %>



<main class="main">


<header class="topbar">


<h1 class="topbar-title">
Upload Profile
</h1>



<div class="topbar-meta">

<code class="endpoint-badge">

POST /profile/upload

</code>


</div>


</header>





<div class="content">






<div class="card">


<div class="card-title">

Import by LinkedIn URL

</div>





<div class="upload-zone">


<div class="upload-zone-icon">

⬆

</div>




<p>

Provide a public LinkedIn profile URL to scrape and store profile data.

</p>






<form method="POST">



<div class="form-row" style="justify-content:center;max-width:600px;margin:auto;">





<div class="form-group">


<label>

LinkedIn Profile URL

</label>




<input

type="url"

name="profileUrl"

value="<%= profileUrl || '' %>"

placeholder="https://www.linkedin.com/in/neal-mohan"

required

/>




</div>





<button class="btn btn-upload">

↑ Upload

</button>






</div>



</form>





</div>






<div style="margin-top:12px;padding:12px 16px;background:var(--bg3);border-radius:6px;border:1px solid var(--border);">


<p style="font-family:var(--mono);font-size:11px;color:var(--text3);">


Example:


<code style="color:var(--accent2)">

https://www.linkedin.com/in/neal-mohan

</code>


</p>



</div>





</div>







<% if(error){ %>



<div class="upload-result">


<div class="error-box">

⚠ Upload Failed

<br>

<%= error %>


</div>


</div>



<% } %>







<% if(result){ %>



<div class="upload-result">


<div class="success-box">


✓ Profile uploaded successfully



</div>





<%

const data = result.data || {};

%>





<% if(data.profile_picture_url || data.name){ %>



<div class="profile-preview">



<% if(data.profile_picture_url){ %>


<img 

src="<%= data.profile_picture_url %>"

class="preview-img"

/>


<% } %>




<div>


<div class="preview-name">

<%= data.name || "LinkedIn Profile" %>

</div>



<div class="preview-text">

Profile data stored successfully

</div>


</div>



</div>



<% } %>






</div>



<% } %>







</div>



</main>



<script src="/js/app.js"></script>



</body>


</html>