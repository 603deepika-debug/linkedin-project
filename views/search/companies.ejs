<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Search Companies — LI Scraper</title>


<link rel="preconnect" href="https://fonts.googleapis.com">

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">


<link rel="stylesheet" href="/css/app.css" />



<style>


.company-grid{

display:grid;

grid-template-columns:repeat(auto-fill,minmax(280px,1fr));

gap:20px;

margin-top:25px;

}



.company-card{

background:var(--bg2);

border:1px solid var(--border);

border-radius:12px;

padding:22px;

transition:.2s;

}



.company-card:hover{

transform:translateY(-5px);

border-color:var(--accent);

box-shadow:var(--shadow);

}



.company-logo{

width:75px;

height:75px;

border-radius:50%;

object-fit:cover;

margin-bottom:15px;

background:white;

}



.company-name{

font-size:20px;

font-weight:800;

margin-bottom:10px;

}



.company-desc{

font-size:13px;

color:var(--text2);

line-height:1.6;

margin-bottom:15px;

}



.company-info{

font-size:13px;

color:var(--text3);

margin-top:8px;

}



.company-link{

display:inline-block;

margin-top:18px;

color:var(--accent);

font-family:var(--mono);

font-size:12px;

text-decoration:none;

}



.company-link:hover{

text-decoration:underline;

}



</style>


</head>



<body>


<%- include('../partials/sidebar', { page:'search-companies' }) %>



<main class="main">


<header class="topbar">


<h1 class="topbar-title">

Search Companies

</h1>



<div class="topbar-meta">


<code class="endpoint-badge">

GET /search/companies

</code>


</div>


</header>





<div class="content">






<div class="card">


<div class="card-title">

Parameters

</div>




<form method="POST">



<div class="form-row">



<div class="form-group">


<label>

Search Keyword

</label>



<input

type="text"

name="keyword"

value="<%= keyword || '' %>"

placeholder="e.g. microsoft"

required

/>



</div>




<button class="btn btn-primary">

Fetch →

</button>




</div>


</form>


</div>









<% if(error){ %>


<div class="alert alert-error">


⚠ <%= error %>


</div>


<% } %>









<% if(result){ %>



<% 

let companies = result.data?.companies || [];

%>






<div class="company-grid">





<% companies.forEach(company=>{ %>





<div class="company-card">





<img

src="<%= company.logo_url %>"

class="company-logo"

onerror="this.style.display='none'"

/>







<div class="company-name">


<%= company.name %>


</div>






<div class="company-desc">


<%= company.description?.substring(0,150) %>...


</div>







<div class="company-info">


🏢 

<%= company.industry || "Industry not available" %>


</div>







<div class="company-info">


📍 

<%= company.location || "Location not available" %>


</div>







<div class="company-info">


👥 

<%= company.follower_count || "Followers not available" %>


</div>








<a

href="<%= company.company_url %>"

target="_blank"

class="company-link">


View LinkedIn →


</a>







</div>





<% }) %>






</div>







<% } %>








</div>


</main>





<script src="/js/app.js"></script>



</body>


</html>