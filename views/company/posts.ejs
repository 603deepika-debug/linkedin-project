<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Company Posts — LI Scraper</title>


<link rel="preconnect" href="https://fonts.googleapis.com">

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">


<link rel="stylesheet" href="/css/app.css" />


<style>


.post-card{

background:var(--bg2);

border:1px solid var(--border);

border-radius:12px;

padding:22px;

margin-top:20px;

}



.post-header{

display:flex;

align-items:center;

gap:15px;

}



.company-logo{

width:55px;

height:55px;

border-radius:50%;

background:var(--bg3);

display:flex;

align-items:center;

justify-content:center;

font-size:25px;

overflow:hidden;

}



.company-logo img{

width:100%;

height:100%;

object-fit:cover;

}



.company-name{

font-size:16px;

font-weight:800;

}



.post-date{

font-size:12px;

color:var(--text3);

}



.post-text{

margin-top:18px;

font-size:14px;

line-height:1.7;

color:var(--text2);

white-space:pre-line;

}



.post-stats{

display:flex;

gap:25px;

margin-top:18px;

padding-top:15px;

border-top:1px solid var(--border);

font-size:13px;

color:var(--text3);

}



.empty{

text-align:center;

padding:50px;

color:var(--text3);

}



</style>


</head>



<body>


<%- include('../partials/sidebar', { page:'company-posts' }) %>



<main class="main">


<header class="topbar">


<h1 class="topbar-title">
Company Posts
</h1>



<div class="topbar-meta">

<code class="endpoint-badge">

GET /company/posts

</code>


</div>


</header>






<div class="content">





<div class="card">


<div class="card-title">

Parameters

</div>



<form method="POST">


<div class="form-row">


<div class="form-group">


<label>

Company Name

</label>



<input

type="text"

name="company"

value="<%= company || '' %>"

placeholder="Microsoft"

required

/>


</div>




<button class="btn btn-primary">

Fetch →

</button>



</div>


</form>



</div>









<% if(error){ %>


<div class="alert alert-error">

<%= error %>

</div>


<% } %>








<%

let posts=[];


if(result && result.data){

posts = result.data.posts || result.data || [];

}


%>









<% if(Array.isArray(posts) && posts.length){ %>





<% posts.forEach(post=>{ %>





<div class="post-card">





<div class="post-header">


<div class="company-logo">


<% if(post.company_logo){ %>


<img src="<%= post.company_logo %>">


<% }else{ %>


🏢


<% } %>


</div>





<div>


<div class="company-name">


<%= post.company_name || company %>


</div>



<div class="post-date">


<%= post.created_at?.formatted || '' %>


</div>


</div>



</div>








<div class="post-text">


<%= post.text || post.post_text || post.content || '' %>


</div>







<div class="post-stats">


<span>

❤️ <%= post.likes || post.total_reactions || 0 %>

</span>



<span>

💬 <%= post.comments || 0 %>

</span>



<span>

🔁 <%= post.shares || 0 %>

</span>



</div>







</div>





<% }) %>







<% } else if(result){ %>


<div class="empty">

No company posts found

</div>


<% } %>






</div>


</main>




<script src="/js/app.js"></script>


</body>

</html>