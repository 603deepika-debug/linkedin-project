<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">


<title>Company Detail</title>


<link rel="stylesheet" href="/css/app.css">



<style>


.company-card{


background:var(--bg2);

border:1px solid var(--border);

border-radius:15px;

overflow:hidden;

margin-top:20px;


}



.cover{


height:160px;

background:linear-gradient(135deg,#7c3aed,#06b6d4);


}



.company-body{


padding:25px;


}



.logo{


width:110px;

height:110px;

border-radius:20px;

object-fit:cover;

border:4px solid white;

margin-top:-60px;


}



.company-name{


font-size:28px;

font-weight:800;

margin-top:15px;


}




.description{


margin-top:15px;

line-height:1.7;

color:#bbb;


}



.info{


display:flex;

gap:15px;

flex-wrap:wrap;

margin-top:20px;


}



.info span{


background:var(--bg3);

padding:10px 15px;

border-radius:20px;


}



.link{


display:inline-block;

margin-top:15px;

color:#38bdf8;


}


</style>


</head>



<body>



<%- include('../partials/sidebar',{page:'company-detail'}) %>



<main class="main">



<header class="topbar">


<h1 class="topbar-title">

Company Detail

</h1>


</header>





<div class="content">



<div class="card">


<form method="POST">


<input

name="company_url"

value="<%= company_url || '' %>"

placeholder="LinkedIn Company URL"

required>


<button class="btn btn-primary">

Fetch →

</button>


</form>


</div>







<% if(error){ %>


<div class="alert alert-error">

<%= error %>

</div>


<% } %>






<% if(result){ %>


<%


const company = 

result.data?.company ||

result.data?.basic_info ||

result.data ||

{};



%>






<div class="company-card">


<div class="cover"></div>



<div class="company-body">





<% if(company.logo_url){ %>


<img

src="<%= company.logo_url %>"

class="logo"


>


<% } %>





<h2 class="company-name">


<%= company.name || "Unknown Company" %>


</h2>






<div class="description">


<%= company.description || "No description available" %>


</div>






<div class="info">



<% if(company.industry){ %>

<span>

🏢 <%= company.industry %>

</span>

<% } %>






<% if(company.location){ %>


<span>

📍 <%= company.location %>

</span>


<% } %>






<% if(company.follower_count){ %>


<span>

👥 <%= company.follower_count %>

</span>


<% } %>



</div>







<% if(company.company_url){ %>


<a 

href="<%= company.company_url %>"

target="_blank"

class="link">

Open LinkedIn

</a>


<% } %>





</div>


</div>






<div class="card">


<h2>

Raw Data

</h2>


<pre>

<%= JSON.stringify(result,null,2) %>


</pre>


</div>





<% } %>




</div>


</main>




</body>


</html>